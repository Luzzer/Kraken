{
  "name": "@uagent/tlon",
  "version": "2026.4.6",
  "description": "UAGENT Tlon/Urbit channel plugin",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@aws-sdk/s3-request-presigner": "3.1024.0",
    "@tloncorp/tlon-skill": "0.3.2",
    "@urbit/aura": "^3.0.0"
  },
  "devDependencies": {
    "uagent": "workspace:*"
  },
  "peerDependencies": {
    "uagent": ">=2026.4.6"
  },
  "peerDependenciesMeta": {
    "uagent": {
      "optional": true
    }
  },
  "uagent": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@uagent/tlon",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.6"
    }
  }
}
