{
  "name": "@uagent/qa-lab",
  "version": "2026.4.6",
  "private": true,
  "description": "UAGENT QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "devDependencies": {
    "uagent": "workspace:*"
  },
  "peerDependencies": {
    "uagent": ">=2026.4.6"
  },
  "peerDependenciesMeta": {
    "uagent": {
      "optional": true
    }
  },
  "uagent": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@uagent/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.6"
    },
    "compat": {
      "pluginApi": ">=2026.4.6"
    }
  }
}
