{
  "name": "@uagent/nextcloud-talk",
  "version": "2026.4.6",
  "description": "UAGENT Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "uagent": "workspace:*"
  },
  "peerDependencies": {
    "uagent": ">=2026.4.6"
  },
  "peerDependenciesMeta": {
    "uagent": {
      "optional": true
    }
  },
  "uagent": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@uagent/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.6"
    },
    "compat": {
      "pluginApi": ">=2026.4.6"
    },
    "build": {
      "uagentVersion": "2026.4.6"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
