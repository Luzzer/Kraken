/.github/dependabot.yml @uagent/secops
/.github/codeql/ @uagent/secops
/.github/workflows/codeql.yml @uagent/secops
/src/security/ @uagent/secops
/src/secrets/ @uagent/secops
/src/config/*secret*.ts @uagent/secops
/src/config/**/*secret*.ts @uagent/secops
/src/gateway/*auth*.ts @uagent/secops
/src/gateway/**/*auth*.ts @uagent/secops
/src/gateway/*secret*.ts @uagent/secops
/src/gateway/**/*secret*.ts @uagent/secops
/src/gateway/security-path*.ts @uagent/secops
/src/gateway/resolve-configured-secret-input-string*.ts @uagent/secops
/src/gateway/protocol/**/*secret*.ts @uagent/secops
/src/gateway/server-methods/secrets*.ts @uagent/secops
/src/agents/*auth*.ts @uagent/secops
/src/agents/**/*auth*.ts @uagent/secops
/src/agents/auth-profiles*.ts @uagent/secops
/src/agents/auth-health*.ts @uagent/secops
/src/agents/auth-profiles/ @uagent/secops
/src/agents/sandbox.ts @uagent/secops
/src/agents/sandbox-*.ts @uagent/secops
/src/agents/sandbox/ @uagent/secops
/src/infra/secret-file*.ts @uagent/secops
/src/cron/stagger.ts @uagent/secops
/src/cron/service/jobs.ts @uagent/secops
/docs/security/ @uagent/secops
/docs/gateway/authentication.md @uagent/secops
/docs/gateway/sandbox-vs-tool-policy-vs-elevated.md @uagent/secops
/docs/gateway/sandboxing.md @uagent/secops
/docs/gateway/secrets-plan-contract.md @uagent/secops
/docs/gateway/secrets.md @uagent/secops
/docs/gateway/security/ @uagent/secops
/docs/cli/approvals.md @uagent/secops
/docs/cli/sandbox.md @uagent/secops
/docs/cli/security.md @uagent/secops
/docs/cli/secrets.md @uagent/secops
/docs/reference/secretref-credential-surface.md @uagent/secops
